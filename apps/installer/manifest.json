{
  "version": 1,
  "packages": [
    {
      "id": "auto-session-name",
      "label": "Auto Session Name",
      "description": "Automatically asks the LLM to name new sessions with a concise title.",
      "category": "Core UX",
      "enabledByDefault": true,
      "tags": [
        "session",
        "ux",
        "automation"
      ],
      "source": {
        "mode": "workspace",
        "path": "../../packages/auto-session-name",
        "npm": "@gnoviawan/pi-auto-session-name"
      }
    },
    {
      "id": "biome-lsp",
      "label": "Biome LSP",
      "description": "Adds Biome lint, format, daemon status, and post-edit checks.",
      "category": "Code Quality",
      "tags": [
        "biome",
        "lint",
        "format"
      ],
      "source": {
        "mode": "workspace",
        "path": "../../packages/biome-lsp",
        "npm": "@gnoviawan/pi-biome-lsp"
      }
    },
    {
      "id": "compact-tool-preview",
      "label": "Compact Tool Preview",
