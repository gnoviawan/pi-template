      "enabledByDefault": true,
      "tags": [
        "usage",
        "metrics",
        "session"
      ],
      "source": {
        "mode": "workspace",
        "path": "../../packages/session-usage",
        "npm": "@gnoviawan/pi-session-usage"
      }
    },
    {
      "id": "setup-providers",
